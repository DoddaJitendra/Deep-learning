#Import libraries
import tensorflow as tf
from tensorflow.keras.datasets import mnist
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Dense, Flatten
from tensorflow.keras.optimizers import SGD, Adam
import matplotlib.pyplot as plt
import time
# Load and preprocess dataset
(x_train, y_train), (x_test, y_test) = mnist.load_data()

x_train = x_train / 255.0
x_test = x_test / 255.0
# model creation
def create_model():
    model = Sequential([
        Flatten(input_shape=(28, 28)),
        Dense(128, activation='relu', kernel_initializer='glorot_uniform'),
        Dense(10, activation='softmax', kernal_initializer='glorot_uniform')
    ])

    return model
# 1. Batch gradient descent
model = create_model()
model.compile(
        optimizer=SGD(learning_rate=0.01),
        loss='sparse_categorical_crossentropy',
        metrics=['accuracy']     )

start = time.time()
history = model.fit(x_train, y_train,epochs=5,batch_size=len(x_train),verbose=1)
end = time.time()
print("\n\nTime taken by BGD:", end - start)
print("Train_accuracy of BGD:", history.history['accuracy'][-1] * 100)
print("Train_loss of BGD:", history.history['loss'][-1])
#Training Loss of BGD
plt.plot(history.history['loss'],label='Training Loss')
plt.xlabel('Epochs')
plt.ylabel('Loss')
plt.title('Training Loss Graph')
plt.legend()
plt.show()
#Training Loss of BGD
plt.plot(history.history['loss'],label='Training Loss')
