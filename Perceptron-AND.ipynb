import numpy as np
import matplotlib.pyplot as plt

# Step 1: Define the dataset for logical AND
# Input features
X = np.array([
    [1,0, 0],
    [1,1, 0],
    [1,0, 1],
    [1,1, 1]
])
# Target labels
y = np.array([0, 0, 0, 1])

# Step 2: Initialize parameters
    #np.random.seed(42)  # For reproducibility
    #np.random.rand(2)  # Random initial weights for two inputs
    #bias = 0 #np.random.rand()  # Random initial bias
weights = [1,1,1]
learning_rate = 0.1  # Small positive value
epochs = 7           # Number of passes over the dataset
                     #print(f"Weights: {weights}")
                     #print(len(X))

# Step 3: Perceptron Learning Algorithm(Moderen)
for epoch in range(epochs):
    print(f"Epoch {epoch + 1}/{epochs}")

       for i in range(len(X)):

        # Compute weighted sum
        z = np.dot(weights, X[i])

        # Activation function (step function)
        y_hat = 1 if z >= 0 else 0

        # Calculate error,orginal ouput - predicted output
        error = y[i] - y_hat

        # Update weights and bias
        weights += learning_rate * error * X[i]

        print(f"Sample {i+1}, Error: {error}, Weights: {weights}")


# Step 4: Visualize the decision boundary
print("Final weights=",weights)
intercept_, coef_= weights[0],weights[1:]

m = -(coef_[0]/coef_[1]) #-(w1/w2)
b = -(intercept_/coef_[1]) # -(w0/w1)

x_input = np.linspace(0.0,1.1,6)
y_input = m*x_input + b #line
print("x=",x_input)
print("y=",y_input)

plt.figure(figsize=(10,6))
plt.plot(x_input,y_input,color='red',linewidth=3)
plt.scatter(X[:,1],X[:,2],c=y,cmap='winter',s=100)


